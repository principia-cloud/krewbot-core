# Vite env example for @krewbot/platform-core's web/ frontend.
# Copy to .env (committed by you in your own deployment repo, or
# supplied via Vercel/Amplify/your platform's env settings) and fill
# in the values from your deployed core stacks.
#
# Vite reads .env automatically at build time. .env.{mode} files
# (.env.development, .env.prod) override based on `vite build --mode`.

# --- Required: backend endpoints ---

# API Gateway URL of the Management API (from `cdk deploy ExampleManagementApiStack` outputs).
VITE_API_URL=https://example.execute-api.us-east-1.amazonaws.com

# Origin where this web app is served. Used to construct the OAuth
# redirect_uri. For local dev you can leave this blank and `npm run dev`
# will use http://localhost:5173.
VITE_APP_BASE_URL=https://app.example.com

# DNS suffix under which workspaces live. The dashboard generates
# {workspaceId}.{VITE_WORKSPACE_DOMAIN_SUFFIX} links to the per-workspace
# ALB. Should match the `*.{suffix}` ACM cert from Example-CertificateStack.
VITE_WORKSPACE_DOMAIN_SUFFIX=ws.example.com

# --- Required: Cognito hosted UI ---

# Cognito hosted-UI domain (no trailing slash). From `Example-AuthStack` outputs.
VITE_COGNITO_DOMAIN=https://your-pool.auth.us-east-1.amazoncognito.com

# Cognito user pool app client id (the one with the hosted-UI flow
# enabled). From `Example-AuthStack` outputs.
VITE_COGNITO_CLIENT_ID=

# --- Optional: branding (defaults shown) ---

# Visible product name. Falls through to "platform" if unset.
# VITE_APP_NAME=platform

# Browser tab title. Falls through to "Platform" if unset.
# VITE_APP_TITLE=Platform

# Logo shown on the login page. Place an image in web/public/ and
# reference it here (or supply an external URL). Default: /logo.svg.
# VITE_BRAND_LOGO_URL=/logo.svg

# Favicon. Default: /favicon.svg.
# VITE_BRAND_FAVICON_URL=/favicon.svg

# --- Optional: PostHog product analytics ---

# If set, the app initializes PostHog at startup. Leave unset to disable.
# VITE_PUBLIC_POSTHOG_TOKEN=
# VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
